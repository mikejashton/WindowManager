<Window x:Class="WindowManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WindowManager.Views.Controls"
        Title="Window Manager" Height="600" Width="800"
        Background="#1E1E1E">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <controls:SidebarControl Grid.Column="0"/>

        <!-- Main Content Area Placeholder -->
        <Border Grid.Column="1" Background="#1E1E1E">
            <TextBlock Text="Select a window to manage"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#888888"
                       FontSize="18"/>
        </Border>
    </Grid>
</Window>
