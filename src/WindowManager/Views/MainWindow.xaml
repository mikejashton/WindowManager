<Window x:Class="WindowManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Window Manager" Height="600" Width="800"
        Background="#1E1E1E">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Placeholder -->
        <Border Grid.Column="0" Background="#2D2D30" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Workspaces"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <Button DockPanel.Dock="Bottom"
                        Content="+ New Workspace"
                        Padding="5"
                        Margin="0,5,0,0"/>
                <!-- TODO: Add workspace list (ItemsControl or ListBox) here -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main Content Area Placeholder -->
        <Border Grid.Column="1" Background="#1E1E1E">
            <TextBlock Text="Select a window to manage"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#888888"
                       FontSize="18"/>
        </Border>
    </Grid>
</Window>
