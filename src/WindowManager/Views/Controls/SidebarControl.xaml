<UserControl x:Class="WindowManager.Views.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#2D2D30" Padding="10">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="Workspaces"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <Button DockPanel.Dock="Bottom"
                    Content="+ New Workspace"
                    Padding="5"
                    Margin="0,5,0,0"/>
            <!-- TODO: Add workspace list (ItemsControl or ListBox) here -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel/>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
